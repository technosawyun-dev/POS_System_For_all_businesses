# Application
APP_NAME=POS_SaaS
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=posdb
DATABASE_USER=posuser
DATABASE_PASSWORD=CHANGE_ME
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Redis
# Docker: use the service name 'redis'. Standalone (no Docker): use 'localhost'
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# JWT
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_COOKIE_NAME=refresh_token
# "lax" if frontend and API share a domain. "none" if the frontend is on a
# different domain than the API (e.g. Vercel frontend + separate API domain) —
# required for the browser to send this cookie cross-site. "none" always implies
# Secure (HTTPS), enforced automatically regardless of APP_ENV.
JWT_REFRESH_TOKEN_COOKIE_SAMESITE=lax
JWT_ISSUER=pos-saas
JWT_AUDIENCE=pos-saas-users

# Celery
# Docker: use service name 'redis'. Standalone: use 'localhost'
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# CORS
# Development: localhost ports. Production: replace with your actual domain(s)
# Example production: CORS_ORIGINS=["https://your-domain.com"]
CORS_ORIGINS=["https://your-domain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# Proxy (set true only when running behind a trusted reverse proxy like Nginx/LB)
TRUST_PROXY_HEADERS=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=100
REGISTRATION_MAX_PER_IP_PER_HOUR=5
REGISTRATION_ABUSE_MAX_PER_IP_PER_DAY=10

# File Uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_CONTENT_TYPES=["image/jpeg","image/png","application/pdf"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Mailtrap Email (transactional emails: password reset, subscription receipts)
EMAIL_ENABLED=true
MAILTRAP_API_TOKEN=CHANGE_ME_your_mailtrap_api_token
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=POS System
FRONTEND_BASE_URL=https://your-domain.com
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# Super Admin — seeded ONCE by running: python scripts/seed.py
# In production (APP_ENV=production), seed_super_admin is skipped automatically.
# Create the admin manually after deploy: use a secure API call or DB insert.
SUPER_ADMIN_EMAIL=admin@your-domain.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# Cloudflare Tunnel — token from Cloudflare dashboard: Zero Trust -> Networks ->
# Tunnels -> Create a tunnel -> Docker. Only needed on the VPS in production.
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_cloudflare_tunnel_token
