# Frontend environment variables (Vite)
# Copy this file to .env.local for local development overrides.
# Do NOT commit .env.local to git.

# Backend API base URL
# Leave empty in development — Vite's proxy (/api → http://localhost:8000) handles routing.
# Set to your production API origin for production builds, e.g. https://api.your-domain.com/api/v1
VITE_API_URL=
