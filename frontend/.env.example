# Frontend environment variables (Vite)
# Copy this file to .env.local for local development overrides.
# Do NOT commit .env.local to git.

# Backend API base URL exposed to the app (used by axios/fetch calls).
# Leave empty in development — Vite's proxy (/api, /uploads) handles routing.
# Set to your production API origin for production builds, e.g. https://api.your-domain.com
VITE_API_URL=

# Backend URL used by Vite's dev-server proxy to forward /api and /uploads requests.
# Defaults to http://localhost:8000 if not set.
VITE_BACKEND_URL=http://localhost:8000
