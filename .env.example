# Docker Compose environment variables
# Copy this file to .env and fill in the values before running docker-compose up.
# See backend/.env.example for the full backend application configuration.

# PostgreSQL (used by the postgres service and to build DATABASE_URL for app services)
DATABASE_NAME=posdb
DATABASE_USER=posuser
DATABASE_PASSWORD=CHANGE_ME

# Nginx
NGINX_HOST=your-domain.com
NGINX_PORT=80
